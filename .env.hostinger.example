NODE_ENV=production
PORT=3000
PUBLIC_BASE_PATH=/
PUBLIC_SITE_URL=https://your-domain.com/
VITE_BASE_PATH=/
VITE_SITE_URL=https://your-domain.com/

# Hostinger Email SMTP (SSL)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hola@your-domain.com
SMTP_PASS=replace-with-the-hostinger-mailbox-password
CONTACT_FROM="Digital Trust Solutions <hola@your-domain.com>"
CONTACT_TO=cotizaciones@your-domain.com

# Optional: set true only when running npm run verify:email to send a test message
EMAIL_SEND_TEST=false

# Private administration panel
ADMIN_EMAIL=your-private-login@example.com
ADMIN_PASSWORD=replace-with-a-long-unique-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

VITE_WHATSAPP_NUMBER=573184289661
WHATSAPP_VERIFY_TOKEN=replace-with-a-long-random-token
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_ACCESS_TOKEN=your-meta-system-user-access-token
WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-number-id
WHATSAPP_GRAPH_API_VERSION=vXX.X
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.6-luna
