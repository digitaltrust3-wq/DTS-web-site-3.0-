{
  "name": "digital-trust-solutions-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently --kill-others-on-fail \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node --watch server/index.mjs",
    "start": "node server/index.mjs",
    "verify:email": "node server/scripts/verify-email.mjs"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.1.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "hls.js": "^1.6.16",
    "lucide-react": "0.487.0",
    "nodemailer": "^9.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "3.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.2.4",
    "tailwindcss": "4.1.12",
    "vite": "6.4.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.3"
    }
  },
  "description": "Official website for Digital Trust Solutions"
}
